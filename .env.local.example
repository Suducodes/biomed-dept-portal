# Copy to .env.local and fill in from your Supabase project settings
# (Project Settings -> API). The anon key is safe to expose in a static site;
# writes are protected by Row Level Security, not by hiding this key.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Leave unset locally. In the GitHub Pages deploy workflow set this to
# "/<your-repo-name>/" so asset URLs resolve on project pages.
# VITE_BASE=/biomed-dept-portal/
